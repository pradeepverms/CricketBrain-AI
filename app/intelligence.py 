def classify_pitch(avg_score, avg_wickets, avg_rr_pp, avg_rr_death):
    """
    Returns pitch type + strategy based on historical venue stats
    """
    score = 0

    if avg_score > 180:
        score += 2
    elif avg_score > 165:
        score += 1
    elif avg_score < 145:
        score -= 2

    if avg_rr_pp > 8.5:
        score += 1
    if avg_rr_death > 11:
        score += 1

    if avg_wickets < 6:
        score += 1

    if score >= 3:
        pitch_type = "🏏 BATTING PARADISE"
        strategy = "Bat first — big totals common. Chase is high risk."
    elif score >= 1:
        pitch_type = "⚖️ BALANCED PITCH"
        strategy = "Toss matters — winner should read conditions and decide."
    elif score >= -1:
        pitch_type = "🎳 BOWLER-FRIENDLY"
        strategy = "Restrict first — 160 is a strong total here."
    else:
        pitch_type = "🎳 SEAM & SWING TRACK"
        strategy = "Bowl first — wickets up front win matches here."

    return pitch_type, strategy


