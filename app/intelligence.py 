def detect_turning_points(over_probs, threshold=0.12):
    """
    Given a list of (over, win_prob) tuples, detect overs
    where probability shifted more than threshold.
    Returns list of dicts with over, shift, direction.
    """
    turning = []
    for i in range(1, len(over_probs)):
        shift = over_probs[i][1] - over_probs[i-1][1]
        if abs(shift) >= threshold:
            turning.append({
                "over": over_probs[i][0],
                "shift": round(shift * 100, 1),
                "direction": "📈 Batting team gained" if shift > 0 else "📉 Bowling team gained",
                "magnitude": "MAJOR" if abs(shift) > 0.20 else "SIGNIFICANT"
            })
    return turning


def why_prob_changed(over_data, prev_prob, curr_prob):
    """Generate NL explanation for why win probability changed"""
    reasons = []
    shift = curr_prob - prev_prob

    wkts  = over_data.get("wickets", 0)
    runs  = over_data.get("runs", 0)
    rr    = over_data.get("run_rate", 0)
    req_rr = over_data.get("required_rr", 0)

    if wkts >= 2:
        reasons.append(f"💀 **{wkts} wickets fell** this over — batting collapse")
    elif wkts == 1:
        reasons.append("💀 **Key wicket** changed the balance")

    if req_rr > 0 and rr > 0:
        if req_rr > rr + 3:
            reasons.append(f"⚡ Required RR ({req_rr:.1f}) outpacing scoring rate ({rr:.1f})")
        elif rr > req_rr + 2:
            reasons.append(f"🏏 Batting team **ahead of target** — scoring {rr:.1f} vs needed {req_rr:.1f}")

    if runs >= 15:
        reasons.append(f"💥 **Big over** — {runs} runs scored, pressure released")
    elif runs <= 3 and wkts == 0:
        reasons.append(f"🔒 **Dot ball over** — scoring dried up, pressure building")

    if not reasons:
        reasons.append(f"📊 Gradual {'improvement' if shift > 0 else 'decline'} in match position")

    return reasons


def what_to_do_next(required_rr, current_rr, wickets_left, overs_left, batting_first=False):
    """Decision engine — what should batting/bowling team do next"""
    decisions = []

    if not batting_first:  # chasing
        gap = required_rr - current_rr
        if gap > 3:
            decisions.append("🚨 **URGENT:** Need a boundary every 2 balls — target big hitters now")
            decisions.append(f"⚡ Required RR is {required_rr:.1f} — send in attacking batter immediately")
        elif gap > 1.5:
            decisions.append(f"⚠️ Required RR rising to {required_rr:.1f} — increase scoring rate")
            decisions.append("🎯 Look for singles + twos to rotate strike, hit boundary when loose ball appears")
        elif gap < -1:
            decisions.append("✅ Ahead of target — keep wickets in hand, don't take unnecessary risks")
            decisions.append(f"🛡️ {wickets_left} wickets remaining — accelerate only in last 4 overs")
        else:
            decisions.append("⚖️ Match is evenly poised — rotate strike, wait for bad ball")

        if wickets_left <= 3 and overs_left > 5:
            decisions.append("💀 **LOW WICKETS WARNING** — protect tail, play smart")
    else:  # bowling
        if required_rr > 10:
            decisions.append(f"🔒 **DEFEND MODE** — chasing team needs {required_rr:.1f} RPO, bowl full & straight")
            decisions.append("🎯 Target stumps, no wide balls — every run is precious")
        elif required_rr < 7:
            decisions.append("⚡ Chase is on — attack early, take wickets to break partnerships")
            decisions.append("🌀 Bring on your best bowler now — a wicket changes everything")

    return decisions


# ─────────────────────────────────────────────────────────
# PLAYOFF PROBABILITY (Monte Carlo)
# ─────────────────────────────────────────────────────────
def playoff_probability(team, current_pts, matches_played, total_matches,
                         all_teams_pts, n_sim=5000):
    """
    Simulate remaining season and calculate playoff qualification probability.
    Top 4 qualify in IPL.
    """
    np.random.seed(42)
    remaining = total_matches - matches_played
    qualify_count = 0

    other_teams = {t: p for t, p in all_teams_pts.items() if t != team}

    for _ in range(n_sim):
        sim_pts = current_pts + np.random.binomial(remaining, 0.5) * 2
        others_sim = {}
        for t, p in other_teams.items():
            t_remaining = total_matches - (p // 2)
            t_remaining = max(0, min(t_remaining, remaining))
            others_sim[t] = p + np.random.binomial(t_remaining, 0.5) * 2

        all_pts = {team: sim_pts, **others_sim}
        ranking = sorted(all_pts, key=lambda x: all_pts[x], reverse=True)
        if team in ranking[:4]:
            qualify_count += 1

    return round(qualify_count / n_sim * 100, 1)


