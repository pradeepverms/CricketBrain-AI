def fantasy_player_reasoning(player_row, captain, vice_captain):
    """Generate WHY THIS PLAYER explanation"""
    p = player_row["player"]
    fp = player_row["fp_total"]
    role = player_row.get("role", "BAT")
    fp_bat = player_row.get("fp_batting", 0)
    fp_bowl = player_row.get("fp_bowling", 0)

    lines = []
    if p == captain:
        lines.append(f"👑 **Captain pick** — highest expected FP ({fp:.0f} pts, 2× multiplier = {fp*2:.0f} pts)")
    elif p == vice_captain:
        lines.append(f"🥈 **Vice-captain** — second highest FP ({fp:.0f} pts, 1.5× = {fp*1.5:.0f} pts)")

    if fp_bat > 40:
        lines.append(f"🏏 Strong batting form — avg {fp_bat:.0f} batting pts recently")
    if fp_bowl > 20:
        lines.append(f"🎳 Wicket-taking threat — avg {fp_bowl:.0f} bowling pts recently")
    if role == "AR":
        lines.append("⚡ All-rounder bonus — contributes on both fronts")

    return lines if lines else [f"📊 Selected for consistency — {fp:.0f} expected pts"]


def diversity_score(team_df):
    """Team diversity: role mix + team mix"""
    roles = team_df["role"].value_counts()
    teams = team_df["team"].value_counts()
    role_entropy = -(roles/roles.sum() * np.log(roles/roles.sum() + 1e-9)).sum()
    team_balance = 1 - abs(teams.iloc[0] - teams.iloc[-1]) / 11 if len(teams) > 1 else 0.5
    return round((role_entropy + team_balance) * 10, 1)


# ─────────────────────────────────────────────────────────
# ANOMALY DETECTION (for run heatmap)
# ─────────────────────────────────────────────────────────
def detect_run_anomalies(over_stats, league_avg_rr=8.5):
    """Detect overs with abnormal run rates"""
    anomalies = []
    if over_stats.empty:
        return anomalies
    mean_rr = over_stats["rr"].mean()
    std_rr  = over_stats["rr"].std()

    for _, row in over_stats.iterrows():
        z = (row["rr"] - mean_rr) / max(std_rr, 0.1)
        if abs(z) > 1.8:
            direction = "spike" if z > 0 else "collapse"
            anomalies.append({
                "over": int(row.get("over_bin", row.get("over_num", 0))),
                "rr":   round(row["rr"], 1),
                "z":    round(z, 2),
                "type": direction,
                "label": f"Over {int(row.get('over_bin', 0)+1)}: {row['rr']:.1f} RPO — {'abnormal scoring spike 🚀' if z>0 else 'scoring collapse 💀'}"
            })
    return anomalies