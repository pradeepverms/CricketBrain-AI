# IMPACT SCORE
# ─────────────────────────────────────────────────────────
def impact_score(runs, sr, avg, wickets=0, economy=None, matches=1):
    """
    Composite match-winning impact score (0-100)
    Considers runs, SR above baseline, wickets, economy
    """
    bat_impact = min((runs / max(avg, 1)) * (sr / 120) * 40, 50)
    bowl_impact = 0
    if wickets > 0 and economy is not None:
        bowl_impact = min(wickets * 10 + max(0, (8 - economy) * 3), 50)
    return round(min(bat_impact + bowl_impact, 100), 1)


# ─────────────────────────────────────────────────────────
# SUSTAINABILITY SCORE (for breakout players)
# ─────────────────────────────────────────────────────────
def sustainability_score(recent_scores, career_avg):
    """
    How sustainable is a breakout? 0-100
    Based on: consistency of recent scores, vs career baseline
    """
    if len(recent_scores) < 3:
        return 50
    recent_avg = np.mean(recent_scores)
    std        = np.std(recent_scores)
    cv         = std / max(recent_avg, 1)
    above_career = (recent_avg - career_avg) / max(career_avg, 1)

    consistency_score = max(0, 100 - cv * 100)
    improvement_score = min(above_career * 50, 50)
    return round((consistency_score * 0.6 + improvement_score * 0.4), 1)


def why_breakout(curr_sr, prev_sr, curr_avg, prev_avg, curr_innings, prev_innings):
    """Generate NL explanation for why a player broke out"""
    reasons = []
    if curr_sr - prev_sr > 15:
        reasons.append(f"⚡ **Strike rate surged** +{curr_sr-prev_sr:.0f} — more aggressive approach")
    if curr_avg - prev_avg > 8:
        reasons.append(f"📈 **Average improved** +{curr_avg-prev_avg:.0f} — better shot selection")
    if curr_innings > prev_innings * 1.3:
        reasons.append(f"🏏 **More opportunities** — batting higher in order or more matches")
    if not reasons:
        reasons.append("📊 Consistent improvement across all metrics")
    return reasons


