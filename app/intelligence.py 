# FORM CLASSIFICATION
# ─────────────────────────────────────────────────────────
def classify_form(recent_avg, career_avg):
    """Returns HOT / GOOD / AVERAGE / DECLINING with emoji"""
    if career_avg <= 0:
        return "⚪ Insufficient Data", 0
    ratio = recent_avg / career_avg
    if ratio >= 1.25:
        return "🔥 HOT FORM", ratio
    elif ratio >= 1.05:
        return "✅ GOOD FORM", ratio
    elif ratio >= 0.85:
        return "📊 AVERAGE FORM", ratio
    else:
        return "📉 DECLINING", ratio


def risk_score(scores):
    """Consistency-based risk score 0-10 (10 = very risky/inconsistent)"""
    if len(scores) < 3:
        return 5.0
    cv = np.std(scores) / max(np.mean(scores), 1)
    return round(min(cv * 10, 10), 1)


def trend_prediction(scores):
    """Linear trend: returning 'improving', 'declining', 'stable'"""
    if len(scores) < 4:
        return "stable", 0
    x = np.arange(len(scores))
    slope = np.polyfit(x, scores, 1)[0]
    if slope > 1.5:
        return "improving", slope
    elif slope < -1.5:
        return "declining", slope
    return "stable", slope


def form_vs_career(recent_avg, career_avg):
    """Returns delta % vs career baseline"""
    if career_avg <= 0:
        return 0
    return round((recent_avg - career_avg) / career_avg * 100, 1)


